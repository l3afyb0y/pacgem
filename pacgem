#!/usr/bin/env bash
set -euo pipefail

readonly PACMAN_BIN="${PACGEM_PACMAN_BIN:-pacman}"
readonly GEMINI_BIN="${PACGEM_GEMINI_BIN:-gemini}"
readonly GEMINI_PROMPT_PREFIX="Please fix the errors with my Arch Linux's pacman."
PACGEM_LOG_FILE=""

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

error() {
  echo "pacgem: $*" >&2
}

cleanup() {
  if [[ -n "${PACGEM_LOG_FILE:-}" && -f "${PACGEM_LOG_FILE:-}" ]]; then
    rm -f "$PACGEM_LOG_FILE"
  fi
}

trap cleanup EXIT

join_values() {
  local values=("$@")
  if ((${#values[@]} == 0)); then
    return
  fi
  printf '%s' "${values[0]}"
  local i
  for ((i = 1; i < ${#values[@]}; i++)); do
    printf ' %s' "${values[$i]}"
  done
  echo
}

extract_flag_context() {
  local flags=()
  local arg
  for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
      flags+=("$arg")
    fi
  done

  if ((${#flags[@]} == 0)); then
    echo "(no flags)"
    return
  fi

  join_values "${flags[@]}"
}

read_user_confirmation() {
  local answer
  printf "Would you like to send the error to Gemini? [y/n] "
  if [[ -t 0 ]]; then
    read -r answer || answer="n"
  else
    if read -r answer; then
      :
    elif [[ -r /dev/tty ]]; then
      read -r answer </dev/tty || answer="n"
    else
      answer="n"
    fi
  fi

  answer="${answer,,}"
  [[ "$answer" == "y" || "$answer" == "yes" ]]
}

build_gemini_prompt() {
  local command_context="$1"
  local pacman_output="$2"
  cat <<EOF
${GEMINI_PROMPT_PREFIX} This happened while running ${command_context}
[ERROR MESSAGE]:
${pacman_output}
EOF
}

detect_terminal() {
  if [[ -n "${PACGEM_TERMINAL:-}" ]]; then
    echo "${PACGEM_TERMINAL}"
    return
  fi

  if [[ -n "${TERMINAL:-}" ]] && command_exists "${TERMINAL}"; then
    echo "${TERMINAL}"
    return
  fi

  local candidates=(kitty alacritty gnome-terminal konsole xfce4-terminal tilix mate-terminal xterm)
  local candidate
  for candidate in "${candidates[@]}"; do
    if command_exists "$candidate"; then
      echo "$candidate"
      return
    fi
  done

  echo ""
}

launch_gemini_in_terminal() {
  local prompt="$1"
  local terminal
  terminal="$(detect_terminal)"
  if [[ -z "$terminal" ]]; then
    return 1
  fi

  local prompt_file
  prompt_file="$(mktemp)"
  printf '%s\n' "$prompt" >"$prompt_file"

  local shell_bin="${SHELL:-/bin/bash}"
  local command
  command="cat \"$prompt_file\" | \"$GEMINI_BIN\" --yolo; status=\$?; rm -f \"$prompt_file\"; echo; echo 'Press Enter to close...'; read -r _; exit \$status"

  case "$(basename "$terminal")" in
    gnome-terminal|tilix|mate-terminal|xfce4-terminal)
      "$terminal" -- "$shell_bin" -lc "$command" || {
        rm -f "$prompt_file"
        return 1
      }
      ;;
    *)
      "$terminal" -e "$shell_bin" -lc "$command" || {
        rm -f "$prompt_file"
        return 1
      }
      ;;
  esac
}

send_to_gemini() {
  local prompt="$1"
  if ! command_exists "$GEMINI_BIN"; then
    error "gemini command not found; install Gemini CLI to use this feature."
    return 1
  fi

  if [[ "${PACGEM_NO_TERMINAL:-0}" == "1" ]]; then
    printf '%s\n' "$prompt" | "$GEMINI_BIN" --yolo
    return $?
  fi

  if ! launch_gemini_in_terminal "$prompt"; then
    error "could not launch a terminal; falling back to current terminal."
    printf '%s\n' "$prompt" | "$GEMINI_BIN" --yolo
  fi
}

run_pacman_with_log() {
  local log_file="$1"
  shift

  "$PACMAN_BIN" "$@" 2>&1 | tee "$log_file"
  local status=${PIPESTATUS[0]}
  return "$status"
}

main() {
  if ! command_exists "$PACMAN_BIN"; then
    error "pacman command not found"
    return 127
  fi

  local command_context
  command_context="$(extract_flag_context "$@")"

  PACGEM_LOG_FILE="$(mktemp)"
  local log_file="$PACGEM_LOG_FILE"

  set +e
  run_pacman_with_log "$log_file" "$@"
  local status=$?
  set -e

  if ((status == 0)); then
    return 0
  fi

  local pacman_output
  pacman_output="$(cat "$log_file")"

  if read_user_confirmation; then
    local gemini_prompt
    gemini_prompt="$(build_gemini_prompt "$command_context" "$pacman_output")"
    send_to_gemini "$gemini_prompt" || true
  fi

  return "$status"
}

main "$@"
